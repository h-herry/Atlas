<?xml version="1.0" encoding="UTF-8"?>
<!--
  Atlas 结构化日志配置 / Atlas Structured Logging Configuration
  基于 09 报告 2.3.2，统一日志格式含 traceId / userId / ip /
  Based on 09 report 2.3.2, unified log format with traceId / userId / ip
-->
<configuration>
    <!-- Spring Boot 默认日志配置继承 / Inherit Spring Boot default logging config -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- 应用名称 / Application name -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name"/>

    <!-- 控制台输出格式: 含 traceId / userId / ip / Console output format: with traceId / userId / ip -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [${APP_NAME:-atlas},%X{traceId:-},%X{userId:-},%X{clientIp:-}] %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- JSON 格式日志（生产环境推荐，输出到文件）/ JSON format log (recommended for production, output to file) -->
    <property name="JSON_LOG_PATTERN"
              value='{"timestamp":"%d{yyyy-MM-dd HH:mm:ss.SSS}","app":"${APP_NAME:-atlas}","traceId":"%X{traceId:-}","userId":"%X{userId:-}","clientIp":"%X{clientIp:-}","level":"%level","thread":"%thread","logger":"%logger{36}","message":"%msg"}%n'/>

    <!-- 控制台 appender（日常开发用文本格式）/ Console appender (text format for development) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件 appender（JSON 格式，按日滚动）/ File appender (JSON format, daily rolling) -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/${APP_NAME:-atlas}.json</file>
        <encoder>
            <pattern>${JSON_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/${APP_NAME:-atlas}.%d{yyyy-MM-dd}.json.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- 错误日志单独输出 / Error log separate output -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <file>logs/${APP_NAME:-atlas}-error.json</file>
        <encoder>
            <pattern>${JSON_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/${APP_NAME:-atlas}-error.%d{yyyy-MM-dd}.json.gz</fileNamePattern>
            <maxHistory>60</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- 默认使用控制台 + JSON 文件输出 / Default: console + JSON file output -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="JSON_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

    <!-- 框架日志级别 / Framework log levels -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="com.alibaba.nacos" level="WARN"/>
    <logger name="org.apache.rocketmq" level="WARN"/>
    <logger name="com.baomidou.mybatisplus" level="DEBUG"/>

    <!-- Atlas 业务日志级别 / Atlas business log level -->
    <logger name="com.atlas" level="INFO"/>
</configuration>
