# Atlas SRM 环境变量模板
# 复制为 .env 后填入实际值

# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT ====================
JWT_SECRET=

# ==================== Nacos ====================
NACOS_SERVER=localhost:8848
NACOS_NAMESPACE=atlas
NACOS_PASSWORD=nacos

# ==================== Sentinel ====================
SENTINEL_DASHBOARD=localhost:8080
SENTINEL_PASSWORD=sentinel

# ==================== RocketMQ ====================
ROCKETMQ_SERVER=localhost:9876

# ==================== RabbitMQ (预留) ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==================== Seata ====================
SEATA_SERVER=localhost:8091

# ==================== Zipkin (预留) ====================
ZIPKIN_SERVER=http://localhost:9411

# ==================== Open Platform ====================
OPEN_APP_SECRET=
OPEN_TOKEN_EXPIRE=7200
