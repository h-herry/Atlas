<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- UserCredential Mapper XML -->
<mapper namespace="com.atlas.user.auth.mapper.UserCredentialMapper">

    <resultMap id="BaseResultMap" type="com.atlas.user.auth.entity.UserCredential">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="channel" property="channel"/>
        <result column="status" property="status"/>
        <result column="locked_until" property="lockedUntil"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, password_hash, channel, status, locked_until, created_at, updated_at
    </sql>

</mapper>
